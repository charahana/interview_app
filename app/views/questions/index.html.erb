<div class="container mt-4">
  <h1>質問一覧</h1>
  <%= link_to "新規作成", new_question_path, class: "btn btn-primary mb-3" %>
  <div class="list-group">
    <% @questions.each do |q| %>
      <div class="list-group-item">
        <%= link_to q.content, question_path(q) %>
        <div class="mt-2">
          <%= link_to "編集", edit_question_path(q), class: "btn btn-sm btn-warning" %>
          <%= link_to "削除", question_path(q), method: :delete, data: { confirm: "本当に削除していい?"}, class: "btn btn-sm btn-danger" %>
        </div>
      </div>
    <% end %>
  </div>
</div>