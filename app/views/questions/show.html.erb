<div class="container mt-4">
  <h2 class="mb-3">問題</h2>
  <div class="card mb-3">
    <div class="card-body">
      <p><%= @question.content %></p>
    </div>
  </div>
  <button class="btn btn-info mb-3" onclick="toggleAnswer()">回答を見る</button>
  <div id="answer" class="card" style="display:none;">
    <div class="card-body">
      <h3>回答</h3>
      <p><%= @question.answer %></p>
    </div>
  </div>
  <div class="mt-3">
    <%= link_to "編集", edit_question_path(@question), class: "btn btn-warning" %>
    <%= link_to "一覧へ戻る", questions_path, class: "btn btn-secondary" %>
  </div>
</div>
<script>
function toggleAnswer() {
  var x = document.getElementById("answer");
  if (x.style.display === "none") {
    x.style.display = "block";
  } else {
    x.style.display = "none";
  }
}
</script>