<%= form_with model: @question do |f| %>
  <div>
    <%= f.label :content, "質問" %><br>
    <%= f.text_area :content %>
  </div>
  <div>
    <%= f.label :answer, "回答" %><br>
    <%= f.text_area :answer %>
  </div>
  <div>
    <%= f.label :category, "カテゴリ" %><br>
    <%= f.text_field :category %>
  </div>
  <%= f.submit "保存" %>
<% end %>